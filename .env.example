# Database
POSTGRES_USER=egg_guardian
POSTGRES_PASSWORD=egg_guardian_secret
POSTGRES_DB=egg_guardian
DATABASE_URL=postgresql+asyncpg://egg_guardian:egg_guardian_secret@postgres:5432/egg_guardian

# MQTT
MQTT_BROKER=mosquitto
MQTT_PORT=11883

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# FCM (mock mode for testing)
FCM_MOCK_MODE=true

# CORS
CORS_ORIGINS=*

# Google Gmail API Configuration
GOOGLE_CLIENT_ID=your_client_id_from_google_cloud
GOOGLE_CLIENT_SECRET=your_client_secret_from_google_cloud
GOOGLE_REFRESH_TOKEN=your_refresh_token_from_auth_script
GOOGLE_SENDER_EMAIL=your_gmail_address@gmail.com